generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Person {
  id         Int       @id @default(autoincrement())
  firstName  String
  middleName String?
  lastName   String
  birthDate  DateTime?
  phone      String?
  email      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  barber Barber?
  client Client?
}

model Barber {
  id             Int      @id @default(autoincrement())
  personId       Int      @unique
  experience     Int?
  specialization String?
  certificates   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  person    Person       @relation(fields: [personId], references: [id])
  schedules Schedule[]
  works     Work[]
  appointments Appointment[]
}

model Client {
  id         Int       @id @default(autoincrement())
  personId   Int       @unique
  discount   Int?      @default(0)
  firstVisit DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  person Person   @relation(fields: [personId], references: [id])
  works  Work[]
  appointments Appointment[]
}

model Service {
  id        Int      @id @default(autoincrement())
  name      String
  duration  Int?
  price     Float
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  works Work[]
  appointments Appointment[]
}

model Schedule {
  id         Int      @id @default(autoincrement())
  barberId   Int
  dayOfWeek  Int
  startTime  String?
  endTime    String?
  isDayOff   Boolean  @default(false)
  createdAt  DateTime @default(now())

  barber Barber @relation(fields: [barberId], references: [id])
}

model Work {
  id        Int      @id @default(autoincrement())
  barberId  Int
  serviceId Int
  clientId  Int
  workDate  DateTime
  createdAt DateTime @default(now())

  barber  Barber  @relation(fields: [barberId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
  client  Client  @relation(fields: [clientId], references: [id])
  review  Review?
}

model Review {
  id         Int      @id @default(autoincrement())
  workId     Int      @unique
  rating     Int
  text       String?
  reviewDate DateTime
  createdAt  DateTime @default(now())

  work Work @relation(fields: [workId], references: [id])
}

model Appointment {
  id         Int      @id @default(autoincrement())
  clientId   Int
  barberId   Int
  serviceId  Int
  date       DateTime
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client  Client  @relation(fields: [clientId], references: [id])
  barber  Barber  @relation(fields: [barberId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
}